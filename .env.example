# ─────────────────────────────────────────────────────────────────────────
# MAGIX — variabili d'ambiente per l'area riservata (backend Vercel Functions)
# Copia questo file in `.env.local` per lo sviluppo locale (`vercel dev`)
# e imposta gli stessi valori in Vercel → Project → Settings → Environment Variables.
# NON committare `.env.local` (è già in .gitignore).
# ─────────────────────────────────────────────────────────────────────────

# Passphrase unica per accedere all'area riservata (/admin).
# Scegli una password robusta: è l'unica barriera d'accesso.
ADMIN_PASSWORD=cambia-questa-password

# Segreto usato per firmare il cookie di sessione (HMAC).
# Genera un valore casuale lungo, es:  openssl rand -hex 32
AUTH_SECRET=cambia-questo-segreto-lungo-e-casuale

# Token del Vercel Blob store (Storage → Blob → connetti al progetto).
# In locale viene popolato automaticamente da `vercel env pull .env.local`.
BLOB_READ_WRITE_TOKEN=

# ⚠ BYPASS TEMPORANEO PER TEST — NON usare in produzione.
# Se impostato a 1/true/on/yes, l'area riservata si apre SENZA password
# (e funziona anche senza ADMIN_PASSWORD/AUTH_SECRET). Compare un avviso rosso.
# Lascialo vuoto/rimuovilo per ripristinare la protezione normale.
ADMIN_BYPASS=
